# n8n webhook used by the contact form (home page + /kontakt/).
# Set the same variable in Railway (Project → Variables) for production.
VITE_KLIMATY_CONTACT_WEBHOOK=https://adrian264-20264.wykr.es/webhook/klimaty_kontakt

# Header auth for the n8n webhook — both NAME and VALUE must match the n8n credential.
# Vite config exposes the "n8n_" prefix so these var names work verbatim in Railway.
n8n_NAME=klimaty-n8n
n8n_VALUE=replace-with-real-header-value
