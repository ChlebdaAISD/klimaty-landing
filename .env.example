# n8n webhook used by the contact form (home page + /kontakt/).
# Set the same variable in Railway (Project → Variables) for production.
VITE_KLIMATY_CONTACT_WEBHOOK=https://adrian264-20264.wykr.es/webhook/klimaty_kontakt

# Value for the "klimaty-n8n" header that authenticates requests to the n8n webhook.
# The header NAME is hardcoded in ContactForm.jsx and must match the n8n credential.
# Vite config exposes the "n8n_" prefix so this var name works verbatim in Railway.
n8n_HEADER=replace-with-real-header-value
